{
  "name": "htracker",
  "version": "0.3.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "seed": "ts-node --project prisma/tsconfig-seed.json prisma/seed.ts",
