# =============================================================================
# HTracker — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
# NEVER commit .env or .env.local to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Required)
# -----------------------------------------------------------------------------
# MongoDB connection string with replica set.
# Prisma requires a replica set for transaction support.
#
# Local Docker (docker-compose.yml):
#   mongodb://htasker:htasker@localhost:27017/htasker?replicaSet=rs0&directConnection=true
#
# MongoDB Atlas:
#   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
DATABASE_URL="mongodb://htasker:htasker@localhost:27017/htasker?replicaSet=rs0&directConnection=true"

# -----------------------------------------------------------------------------
# Authentication (Required)
# -----------------------------------------------------------------------------
# Secret used to sign JWTs and session cookies.
# Generate a strong random value: openssl rand -hex 32
AUTH_SECRET="change-me-generate-with-openssl-rand-hex-32"

# Public-facing URL of the application (required in production)
# Example: https://htasker.yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# OAuth — Google (Optional)
# -----------------------------------------------------------------------------
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <NEXTAUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# OAuth — GitHub (Optional)
# -----------------------------------------------------------------------------
# Create an OAuth App at: https://github.com/settings/developers
# Authorization callback URL: <NEXTAUTH_URL>/api/auth/callback/github
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# -----------------------------------------------------------------------------
# E2E Testing (Optional — CI only)
# -----------------------------------------------------------------------------
# Credentials for a test account used by Playwright E2E tests.
# Do NOT use a real user account.
# E2E_EMAIL="e2e-test@example.com"
# E2E_PASSWORD="a-strong-test-password"

# -----------------------------------------------------------------------------
# Docker Compose — MongoDB credentials (Required when using docker-compose.yml)
# -----------------------------------------------------------------------------
# These are used to create the MongoDB root user inside the Docker container.
# Must be set before running: docker compose up
# Generate a strong password: openssl rand -base64 24
MONGO_INITDB_ROOT_USERNAME="htasker"
MONGO_INITDB_ROOT_PASSWORD="change-me-use-a-strong-password"
